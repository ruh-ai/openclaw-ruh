CODEX_TASK_LOOP_REPO_PATH=/srv/openclaw-ruh
CODEX_TASK_LOOP_STATE_DIR=/var/lib/openclaw-codex-loop
CODEX_TASK_LOOP_LOG_LEVEL=info

# Required integrations
LINEAR_API_KEY=replace-with-linear-api-key
GH_TOKEN=replace-with-github-token
OPENAI_API_KEY=replace-with-openai-api-key

# Optional overrides
CODEX_TASK_LOOP_DRY_RUN=false
CODEX_TASK_LOOP_MODEL=gpt-5.4
OPENCLAW_CODEX_AGENT_ID=codex-task-loop
