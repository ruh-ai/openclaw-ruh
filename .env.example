# ─────────────────────────────────────────────────────────────────────────────
# OpenClaw Deploy — Production Environment Variables
# Copy this file to .env and fill in your values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
DAYTONA_API_KEY=your_daytona_api_key_here

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=changeme
POSTGRES_DB=openclaw
DATABASE_URL=postgresql://openclaw:changeme@postgres:5432/openclaw

# ── LLM provider keys (set at least one) ──────────────────────────────────────
# Priority order inside the sandbox: OpenRouter → OpenAI → Anthropic → Gemini
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ── Optional: messaging channel tokens ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# ── Agent Builder UI ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_COOKIES_DOMAIN=
NEXT_PUBLIC_AUTH_URL=
NEXT_PUBLIC_APP_URL=
SIMPLE_LOGIN_PASSWORD=
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=

# ── Backend server settings ────────────────────────────────────────────────────
PORT=8000
# Comma-separated list of origins allowed by CORS.
# In production behind nginx, set this to your public domain.
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000,http://localhost:3001,https://yourdomain.com
