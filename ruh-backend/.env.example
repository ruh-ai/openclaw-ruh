# ─────────────────────────────────────────────────────────────────────────────
# OpenClaw Backend (TypeScript/Bun) — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
DAYTONA_API_KEY=your_daytona_api_key_here

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# When running via docker-compose the host is "postgres" (service name).
# When running locally point to localhost.
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=changeme
POSTGRES_DB=openclaw
DATABASE_URL=postgresql://openclaw:changeme@localhost:5432/openclaw

# ── Shared Codex/OpenClaw OAuth bootstrap (optional) ─────────────────────────
# If present, new sandboxes prefer these host auth files over API-key bootstrap.
# Leave blank to use the default host paths:
#   $HOME/.openclaw/credentials/oauth.json
#   $HOME/.codex/auth.json
OPENCLAW_SHARED_OAUTH_JSON_PATH=
CODEX_AUTH_JSON_PATH=
OPENCLAW_SHARED_CODEX_MODEL=openai-codex/gpt-5.4

# ── LLM provider keys (required only if shared auth is absent) ───────────────
# Legacy priority order inside the sandbox: OpenRouter → OpenAI → Anthropic → Gemini
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ── Optional: messaging channel tokens ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# ── Server settings ────────────────────────────────────────────────────────────
PORT=8000
# Comma-separated list of origins allowed by CORS.
# In production behind nginx, set this to your public domain.
ALLOWED_ORIGINS=http://localhost:3000
# Required only for the admin retrofit route and `bun run retrofit:shared-codex`
OPENCLAW_ADMIN_TOKEN=
