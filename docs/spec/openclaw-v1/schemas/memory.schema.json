{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.ruh.ai/spec/v1/schemas/memory.schema.json",
  "title": "OpenClaw Memory Entry and Index",
  "description": "Tier/lane-aware, role-attested, status-tracked memory. See spec/openclaw-v1/004-memory-model.md.",
  "type": "object",
  "$defs": {
    "MemoryEntry": {
      "description": "A single .openclaw/memory/<type>/<slug>.md file, frontmatter portion.",
      "type": "object",
      "required": [
        "id", "type", "title", "description",
        "tier", "lane", "source_identity", "source_channel", "status",
        "created_at", "updated_at", "spec_version"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "type": { "enum": ["project", "user", "feedback", "reference"] },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1, "maxLength": 200 },
        "tier": { "type": "integer", "enum": [1, 2, 3] },
        "lane": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "source_identity": {
          "type": "string",
          "minLength": 1,
          "description": "Authenticated identity attributed by runtime, never client-supplied."
        },
        "source_channel": {
          "enum": ["email", "dashboard", "agent", "import", "teams", "webhook", "other"]
        },
        "status": {
          "enum": ["proposed", "flagged", "confirmed", "permanent", "deprecated"]
        },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": ["string", "null"], "format": "date-time" },
        "supersedes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        },
        "superseded_by": {
          "type": ["string", "null"],
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "related": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        },
        "important": {
          "type": "boolean",
          "default": false,
          "description": "Survives reactive compaction. Use sparingly."
        },
        "spec_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[a-z0-9.]+)?$"
        }
      }
    },
    "MemoryAuthority": {
      "description": "Maps tier+lane → identities authorized to write at that tier+lane. Lives in pipeline-manifest.json.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tier", "lane", "writers"],
        "additionalProperties": false,
        "properties": {
          "tier": { "type": "integer", "enum": [1, 2, 3] },
          "lane": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "writers": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "uniqueItems": true,
            "description": "Identities (typically email addresses or agent URIs) authorized to write."
          }
        }
      }
    },
    "MemoryWriteRequest": {
      "description": "A pending write before the runtime applies tier policy.",
      "type": "object",
      "required": ["tier", "lane", "source_identity", "source_channel", "content"],
      "additionalProperties": false,
      "properties": {
        "tier": { "type": "integer", "enum": [1, 2, 3] },
        "lane": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "source_identity": { "type": "string", "minLength": 1 },
        "source_channel": {
          "enum": ["email", "dashboard", "agent", "import", "teams", "webhook", "other"]
        },
        "content": {
          "type": "object",
          "required": ["type", "title", "body"],
          "additionalProperties": false,
          "properties": {
            "type": { "enum": ["project", "user", "feedback", "reference"] },
            "title": { "type": "string", "minLength": 1 },
            "description": { "type": "string", "maxLength": 200 },
            "body": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "MemoryQueryFilter": {
      "description": "Allowed filter shape for ctx.memory.list().",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "types": {
          "type": "array",
          "items": { "enum": ["project", "user", "feedback", "reference"] }
        },
        "lanes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        },
        "statuses": {
          "type": "array",
          "items": { "enum": ["confirmed", "permanent"] },
          "description": "ONLY confirmed and permanent are queryable by agents. proposed and flagged are runtime-only."
        }
      }
    }
  }
}
