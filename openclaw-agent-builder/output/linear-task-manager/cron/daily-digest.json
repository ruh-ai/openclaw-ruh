{
  "name": "Linear Task Daily Digest",
  "enabled": true,
  "schedule": {
    "kind": "cron",
    "expr": "30 2 * * *",
    "tz": "UTC"
  },
  "sessionTarget": "isolated",
  "payload": {
    "kind": "agentTurn",
    "message": "Run daily Linear task digest workflow",
    "model": "openrouter/anthropic/claude-sonnet-4.5",
    "timeoutSeconds": 600
  }
}
