._*
Thumbs.db

# ── Environment & secrets ─────────────────────────────────────────────────────
backend/.env
frontend/.env.local
frontend/.env*.local
*.env

# ── Python ────────────────────────────────────────────────────────────────────
backend/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
*.egg-info/
dist/
build/
