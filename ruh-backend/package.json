{
  "name": "ruh-backend",
  "version": "1.0.0",
  "description": "OpenClaw Backend API — TypeScript/Bun",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun run test:unit && bun test tests/contract/ tests/e2e/ && bun run test:security && bun test tests/smoke/",
    "test:unit": "bun run test:unit:pure && bun run scripts/run-z-routes-tests.ts",
    "test:unit:pure": "bun test tests/unit/stores/ && bun test tests/unit/clients/ && bun test tests/unit/auth/ && bun test tests/unit/db/ && bun test tests/unit/utils/",
    "test:unit:routes": "bun run scripts/run-z-routes-tests.ts",
    "test:integration": "bun test tests/integration/",
    "test:e2e": "bun test tests/e2e/",
    "test:smoke": "bun test tests/smoke/",
    "test:security": "bun test tests/security/auth.test.ts && bun test tests/security/cors.test.ts && bun test tests/security/injection.test.ts && bun test tests/security/shellCommands.test.ts",
    "test:contract": "bun test tests/contract/",
    "test:fast": "bun run test:unit && bun test tests/e2e/ tests/security/ tests/contract/",
    "test:coverage": "bun run scripts/run-coverage.ts",
    "test:watch": "bun test --watch tests/unit/",
    "retrofit:shared-codex": "bun run scripts/retrofit-shared-codex.ts",
    "seed:test-users": "bun run scripts/seed-test-users.ts",
    "seed:demo-marketplace": "bun run scripts/seed-demo-marketplace.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/sdk-trace-base": "^1.25.0",
    "@opentelemetry/semantic-conventions": "^1.25.0",
    "@ruh/logger": "file:../packages/logger",
    "axios": "^1.7.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.19.0",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "bun-types": "latest",
    "supertest": "^7.2.2",
    "typescript": "^5.5.0"
  }
}
