OPENCLAW_REVIEW_WEBHOOK_TOKEN=replace-with-a-long-random-token
OPENCLAW_REVIEW_GITHUB_WEBHOOK_SECRET=replace-with-a-second-long-random-secret
OPENCLAW_REVIEW_GITHUB_TOKEN=replace-with-a-fine-grained-github-token

# Provider credentials used by OpenClaw on the review host.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional runtime settings.
OPENCLAW_REVIEW_AGENT_ID=github-review
OPENCLAW_REVIEW_BRIDGE_PORT=8787
OPENCLAW_BIN=/home/pd/.npm-global/bin/openclaw
