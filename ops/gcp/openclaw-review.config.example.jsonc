{
  // Example OpenClaw gateway configuration for the local review bridge.
  // The bridge is the only public entrypoint. It shells into the local
  // gateway with `openclaw agent --agent github-review`.
  "gateway": {
    "server": {
      "host": "127.0.0.1",
      "port": 18789
    }
  },
  "agents": {
    "list": [
      {
        "id": "github-review",
        "workspace": "/srv/openclaw/github-review-workspace"
      }
    ]
  }
}
