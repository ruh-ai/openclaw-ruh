{
  "name": "agent-builder-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "npm run test:unit:api && npm run test:unit:store && npm run test:unit:ag-ui && npm run test:unit:core",
    "test:unit:api": "bun test lib/openclaw/api.test.ts",
    "test:unit:store": "bun test hooks/use-openclaw-chat.test.ts",
    "test:unit:ag-ui": "bun test lib/openclaw/ag-ui/__tests__/builder-agent.test.ts lib/openclaw/ag-ui/__tests__/progressive-wizard-flow.test.ts",
    "test:unit:core": "bun run scripts/run-unit-tests.ts",
    "test:unit:services-cookies": "bun test services/authCookies.test.ts services/authCookies.shared.test.ts",
    "test:unit:services-helper": "bun test services/helper.test.ts",
    "test:unit:services-axios": "bun test services/axios.test.ts",
    "test:unit:hooks": "bun test hooks/ --path-ignore-patterns 'hooks/use-openclaw-chat.test.ts'",
    "test:unit:eval-scorer": "bun test lib/openclaw/__tests__/eval-trace-scorer.test.ts",
    "test:unit:eval-runner": "bun test lib/openclaw/eval-runner.test.ts",
    "test:unit:lib": "bun test lib/ middleware.test.ts --path-ignore-patterns 'lib/openclaw/api.test.ts' --path-ignore-patterns 'lib/openclaw/ag-ui/__tests__/builder-agent.test.ts' --path-ignore-patterns 'lib/openclaw/ag-ui/__tests__/progressive-wizard-flow.test.ts' --path-ignore-patterns 'lib/openclaw/__tests__/eval-trace-scorer.test.ts' --path-ignore-patterns 'lib/openclaw/eval-runner.test.ts' --path-ignore-patterns 'lib/openclaw/__tests__/eval-pipeline.integration.test.ts'",
    "test:unit:app-isolated": "bun test app/api/auth.test.ts 'app/(platform)/agents/create/_components/review/ReviewAgent.test.ts' 'app/(platform)/agents/create/_components/copilot/__tests__/lifecycle-stage-logic.test.ts' 'app/(platform)/agents/[id]/chat/_components/tab-workspace-autoswitch.test.ts'",
    "test:unit:app": "bun run scripts/run-unit-tests.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --path-ignore-patterns 'e2e/**' --path-ignore-patterns 'test-results/**' && bun run scripts/check-coverage.ts"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.52",
    "@ag-ui/core": "^0.0.52",
    "@anthropic-ai/sdk": "^0.88.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@hookform/resolvers": "^5.0.1",
    "@langfuse/otel": "5.1.0",
    "@langfuse/tracing": "5.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/sdk-node": "0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@radix-ui/react-dialog": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.2",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.98.0",
    "axios": "^1.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fast-json-patch": "^3.1.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.55.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.2",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.2.0",
    "tw-animate-css": "^1.2.5",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.3"
  },
  "optionalDependencies": {
    "lightningcss-linux-arm64-gnu": "^1.32.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^6"
  },
  "packageManager": "yarn@4.12.0"
}
