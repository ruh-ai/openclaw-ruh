{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.ruh.ai/spec/v1/schemas/milestone.schema.json",
  "title": "OpenClaw Milestone Tracking",
  "description": "Contract for performance milestones with measurement windows, exit ramps, and audit-grade evidence. See spec/openclaw-v1/016-milestone-tracking.md.",
  "type": "object",
  "$defs": {
    "MilestonesConfig": {
      "description": "pipeline-manifest.json's milestones field. Optional — only pipelines with contractual milestone obligations declare it.",
      "type": "object",
      "required": ["go_live_at", "definitions"],
      "additionalProperties": false,
      "properties": {
        "go_live_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp at which the customer-facing 'go-live' clock starts. All trigger durations are computed from here."
        },
        "definitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/MilestoneDefinition" },
          "minItems": 1
        },
        "classification_function": {
          "type": "string",
          "minLength": 1,
          "description": "Path to module exporting (session) -> EstimateKind."
        },
        "rework_function": {
          "type": "string",
          "minLength": 1,
          "description": "Path to module exporting (session) -> AutonomousStatus."
        },
        "evaluation_cadence": {
          "type": "string",
          "default": "0 0 * * *",
          "description": "Cron expression for automated milestone evaluations. Default: daily at 00:00 UTC."
        }
      }
    },
    "MilestoneDefinition": {
      "type": "object",
      "required": ["id", "name", "trigger", "metric"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$",
          "description": "Stable identifier (e.g., M2, M4, M6, M12)."
        },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "trigger": { "$ref": "#/$defs/MilestoneTrigger" },
        "metric": { "$ref": "#/$defs/MilestoneMetric" },
        "qualifying_filter": {
          "type": "object",
          "additionalProperties": true,
          "description": "Per-pipeline filter applied to the population before metric computation."
        },
        "exit_ramp": { "$ref": "#/$defs/ExitRamp" },
        "evidence_required": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Evidence artifacts that must be produced and exportable for this milestone."
        }
      }
    },
    "MilestoneTrigger": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "duration"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "after_go_live" },
            "duration": {
              "type": "string",
              "pattern": "^P[0-9]+[YMDW]([0-9]+[YMDW])*$|^P[0-9]+[YMDW]?T[0-9]+[HMS]$",
              "description": "ISO-8601 duration after go_live_at."
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "at"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "calendar_date" },
            "at": { "type": "string", "format": "date-time" }
          }
        }
      ]
    },
    "MilestoneMetric": {
      "oneOf": [
        { "$ref": "#/$defs/PassRateMetric" },
        { "$ref": "#/$defs/AbsoluteCountMetric" },
        { "$ref": "#/$defs/ToleranceConvergenceMetric" }
      ]
    },
    "PassRateMetric": {
      "type": "object",
      "required": ["kind", "denominator", "numerator", "target", "comparison"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "pass_rate" },
        "denominator": {
          "type": "object",
          "required": ["kind"],
          "additionalProperties": true,
          "properties": {
            "kind": { "enum": ["filtered_estimates", "all_estimates"] },
            "filter": {
              "type": "object",
              "additionalProperties": true,
              "description": "Filter shape passed to the classifier. e.g., { estimate_kind: 'routine' }."
            }
          }
        },
        "numerator": {
          "type": "object",
          "required": ["kind", "definition"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "autonomous_count" },
            "definition": {
              "type": "object",
              "required": ["rework_threshold"],
              "additionalProperties": false,
              "properties": {
                "rework_threshold": {
                  "enum": ["lead_estimator_signoff_only", "no_human_intervention", "minor_corrections_allowed", "custom"],
                  "description": "REQUIRED. Defines what counts as 'autonomous'. 'lead_estimator_signoff_only' means only the lead-estimator approval action is allowed; any other human edit disqualifies. 'custom' requires the custom_function field."
                },
                "human_intervention_disqualifies": {
                  "type": "boolean",
                  "default": true
                },
                "custom_function": {
                  "type": "string",
                  "description": "Required when rework_threshold is 'custom'."
                }
              },
              "if": { "properties": { "rework_threshold": { "const": "custom" } } },
              "then": { "required": ["rework_threshold", "custom_function"] }
            }
          }
        },
        "comparison_window": { "$ref": "#/$defs/MeasurementWindow" },
        "target": { "type": "number", "minimum": 0, "maximum": 1 },
        "comparison": { "enum": [">=", ">", "==", "<", "<="] }
      }
    },
    "AbsoluteCountMetric": {
      "type": "object",
      "required": ["kind", "target", "comparison"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "absolute_count" },
        "target": { "type": "integer", "minimum": 0 },
        "comparison": { "enum": [">=", ">", "==", "<", "<="] },
        "comparison_window": { "$ref": "#/$defs/MeasurementWindow" }
      }
    },
    "ToleranceConvergenceMetric": {
      "type": "object",
      "required": ["kind", "tolerance_percent"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "tolerance_convergence" },
        "comparison_window": { "$ref": "#/$defs/MeasurementWindow" },
        "tolerance_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Maximum acceptable percentage delta between agent output and ground-truth final estimate, averaged across the window."
        }
      }
    },
    "MeasurementWindow": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "duration"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "rolling" },
            "duration": {
              "type": "string",
              "pattern": "^P[0-9]+[YMDW]$",
              "description": "ISO-8601 duration ending at evaluation time. e.g., P30D = trailing 30 days."
            }
          }
        },
        {
          "type": "object",
          "required": ["kind"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "calendar_month" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "start"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "since_go_live" },
            "start": { "type": "string", "format": "date-time" }
          }
        }
      ]
    },
    "ExitRamp": {
      "description": "Refund / service-credit / termination contract attached to a milestone. The runtime computes the obligation; payment lives outside the spec.",
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": ["pro_rated_refund", "fixed_refund", "termination_only", "service_credit"]
        },
        "formula": {
          "type": "string",
          "description": "Refund computation expression. Variables: build_fee, target_months, months_elapsed, months_overrun. e.g., 'build_fee * (target_months - months_elapsed) / 12'. Required for kind=pro_rated_refund."
        },
        "build_fee_usd": {
          "type": "number",
          "minimum": 0,
          "description": "The build fee that scales the formula. Required for kind=pro_rated_refund and kind=fixed_refund."
        },
        "target_months": {
          "type": "integer",
          "minimum": 1,
          "description": "Months from go-live where the milestone is targeted. Required for kind=pro_rated_refund."
        },
        "fixed_amount_usd": {
          "type": "number",
          "minimum": 0,
          "description": "Required for kind=fixed_refund."
        },
        "cap_fraction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Maximum refund as a fraction of build_fee_usd."
        },
        "cap_usd": {
          "type": "number",
          "minimum": 0,
          "description": "Alternative absolute cap. cap_fraction and cap_usd are mutually exclusive."
        },
        "service_credit_terms": {
          "type": "string",
          "description": "Required for kind=service_credit. Free-form description of the service credit (e.g., 'one month of platform license')."
        },
        "authorized_triggers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Identities authorized to trigger the exit ramp on the customer side. Defaults to the pipeline manifest's primary contact."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "pro_rated_refund" } } },
          "then": { "required": ["kind", "formula", "build_fee_usd", "target_months"] }
        },
        {
          "if": { "properties": { "kind": { "const": "fixed_refund" } } },
          "then": { "required": ["kind", "fixed_amount_usd"] }
        },
        {
          "if": { "properties": { "kind": { "const": "service_credit" } } },
          "then": { "required": ["kind", "service_credit_terms"] }
        },
        {
          "description": "cap_fraction and cap_usd are mutually exclusive.",
          "not": {
            "type": "object",
            "required": ["cap_fraction", "cap_usd"]
          }
        }
      ]
    },
    "MilestoneEvidence": {
      "description": "Produced by every milestone evaluation; persisted server-side and exportable for customer audit.",
      "type": "object",
      "required": ["milestone_id", "evaluated_at", "metric_value", "target", "comparison", "passed", "denominator", "numerator"],
      "additionalProperties": false,
      "properties": {
        "milestone_id": { "type": "string", "pattern": "^[A-Z][A-Za-z0-9]*$" },
        "evaluated_at": { "type": "string", "format": "date-time" },
        "window": { "$ref": "#/$defs/MeasurementWindow" },
        "metric_value": { "type": "number" },
        "target": { "type": "number" },
        "comparison": { "enum": [">=", ">", "==", "<", "<="] },
        "passed": { "type": "boolean" },
        "denominator": {
          "type": "object",
          "required": ["total", "qualifying"],
          "additionalProperties": false,
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "breakdown": {
              "type": "object",
              "additionalProperties": { "type": "integer", "minimum": 0 }
            },
            "qualifying": { "type": "integer", "minimum": 0 }
          }
        },
        "numerator": {
          "type": "object",
          "required": ["total", "qualifying"],
          "additionalProperties": false,
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "breakdown": {
              "type": "object",
              "additionalProperties": { "type": "integer", "minimum": 0 }
            },
            "qualifying": { "type": "integer", "minimum": 0 }
          }
        },
        "per_estimate_records": {
          "type": "array",
          "items": { "$ref": "#/$defs/PerEstimateRecord" }
        }
      }
    },
    "PerEstimateRecord": {
      "type": "object",
      "required": ["session_id", "estimate_kind", "autonomous_status", "completed_at"],
      "additionalProperties": false,
      "properties": {
        "session_id": { "type": "string", "minLength": 1 },
        "estimate_kind": { "$ref": "#/$defs/EstimateKind" },
        "autonomous_status": { "$ref": "#/$defs/AutonomousStatus" },
        "completed_at": { "type": "string", "format": "date-time" },
        "deliverables_count": { "type": "integer", "minimum": 0 },
        "rework_summary": { "type": "string" }
      }
    },
    "EstimateKind": {
      "enum": ["routine", "edge_specialty", "edge_ground_up", "edge_commercial", "unclassifiable"]
    },
    "AutonomousStatus": {
      "enum": ["autonomous", "minor_correction", "rework", "abandoned", "in_progress"]
    },
    "MilestoneEventDecisionTypes": {
      "description": "Decision-log types added by this section. Reference for 005-decision-log.md.",
      "enum": [
        "milestone_classification",
        "milestone_reclassification",
        "milestone_autonomy_evaluated",
        "milestone_evaluated",
        "milestone_missed",
        "milestone_signoff_recorded",
        "milestone_exit_ramp_triggered"
      ]
    }
  }
}
