# Required
DAYTONA_API_KEY=your_daytona_api_key_here

# LLM provider keys — set the one you use (priority: OpenRouter → OpenAI → Anthropic → Gemini)
# All keys are read server-side; none are exposed to the UI.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Optional: messaging channel tokens
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# Server settings
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000
