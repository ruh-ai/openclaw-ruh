# ─────────────────────────────────────────────────────────────────────────────
# OpenClaw Deploy — Production Environment Variables
# Copy this file to .env and fill in your values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── Prerequisites ─────────────────────────────────────────────────────────────
# Docker must be running on the host. Sandboxes are created as local Docker containers.
# No Daytona API key required.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=changeme
POSTGRES_DB=openclaw
DATABASE_URL=postgresql://openclaw:changeme@postgres:5432/openclaw

# ── Shared Codex/OpenClaw OAuth bootstrap (optional) ─────────────────────────
# If present, new sandboxes prefer these host auth files over API-key bootstrap.
# Leave blank to use the default host paths:
#   $HOME/.openclaw/credentials/oauth.json
#   $HOME/.codex/auth.json
OPENCLAW_SHARED_OAUTH_JSON_PATH=
CODEX_AUTH_JSON_PATH=
OPENCLAW_SHARED_CODEX_MODEL=openai-codex/gpt-5.4

# ── LLM provider keys (required only if shared auth is absent) ───────────────
# Legacy priority order inside the sandbox: OpenRouter → OpenAI → Anthropic → Gemini
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ── Optional: messaging channel tokens ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# ── Backend server settings ────────────────────────────────────────────────────
PORT=8000
# Comma-separated list of origins allowed by CORS.
# In production behind nginx, set this to your public domain.
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000,http://localhost:3001,https://yourdomain.com
# Required only for the admin retrofit route and `cd ruh-backend && bun run retrofit:shared-codex`
OPENCLAW_ADMIN_TOKEN=
