# Daytona sandbox configuration for ${SYSTEM_NAME}
# Generated by Agent Factory

name: "${SYSTEM_NAME}"
snapshot: "daytona-medium"
auto_stop: false

# Environment variables (set actual values before deploying)
env:
  DATA_INGESTION_BASE_URL: "https://ingestion-service-s45p.onrender.com"
  DATA_INGESTION_ORG_ID: "${DATA_INGESTION_ORG_ID}"
  DATA_INGESTION_AGENT_ID: "${DATA_INGESTION_AGENT_ID}"
  DATA_INGESTION_TOKEN: ""
  ${ADDITIONAL_ENV_VARS}

# Post-create setup commands
setup:
  - "chmod +x /workspace/setup.sh"
  - "/workspace/setup.sh"

# Health check
health:
  endpoint: "http://localhost:18789/health"
  interval: 30
  timeout: 10
  retries: 3
