{
  "$schema": "https://raw.githubusercontent.com/nickvdyck/tauri-v2-schema/main/schema.json",
  "productName": "Ruh Desktop",
  "identifier": "ai.ruh.desktop",
  "version": "0.1.0",
  "build": {
    "devUrl": "http://localhost:3001",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ruh — Your AI Assistant",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "notification": {
      "all": true
    },
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
