#!/bin/sh

# Run unit tests for services with changed files
CHANGED=$(git diff HEAD @{push} --name-only 2>/dev/null || git diff HEAD~1 --name-only)

# Resolve bun binary — prefer PATH bun, fall back to ~/.bun/bin/bun
BUN=$(which bun 2>/dev/null || echo "$HOME/.bun/bin/bun")


if echo "$CHANGED" | grep -q "^ruh-backend/"; then
  echo "🧪 Running ruh-backend tests..."
  cd ruh-backend
  "$BUN" run test:unit || exit 1
  cd ..
fi

if echo "$CHANGED" | grep -q "^agent-builder-ui/"; then
  echo "🧪 Running agent-builder-ui tests..."
  cd agent-builder-ui
  "$BUN" run test:unit || exit 1
  cd ..
fi

if echo "$CHANGED" | grep -q "^ruh-frontend/"; then
  echo "🧪 Running ruh-frontend tests..."
  # Resolve node — prefer PATH node, fall back to common nvm/homebrew locations
  NODE=$(which node 2>/dev/null \
    || ls "$HOME"/.nvm/versions/node/*/bin/node 2>/dev/null | sort -V | tail -1 \
    || echo "")
  if [ -z "$NODE" ]; then
    echo "⚠️  node not found — skipping ruh-frontend tests"
  else
    cd ruh-frontend && "$NODE" node_modules/.bin/jest --ci --passWithNoTests || exit 1
    cd ..
  fi
fi

if echo "$CHANGED" | grep -q "^admin-ui/"; then
  echo "🧪 Running admin-ui tests..."
  cd admin-ui && "$BUN" run test || exit 1
  cd ..
fi

if echo "$CHANGED" | grep -q "^packages/marketplace-ui/"; then
  echo "🧪 Running marketplace-ui tests..."
  cd packages/marketplace-ui && "$BUN" test || exit 1
  cd ..
fi

# KB annotation validation — blocks push if @kb: refs point to deleted/renamed notes
if [ -f "scripts/check-kb-annotations.ts" ]; then
  echo "📚 Validating KB annotations..."
  "$BUN" scripts/check-kb-annotations.ts --json 2>/dev/null | grep -q '"brokenRefs": \[\]' || {
    echo "❌ Broken @kb: references found. Run: bun scripts/check-kb-annotations.ts"
    exit 1
  }
fi

echo "✓ Pre-push checks passed"
