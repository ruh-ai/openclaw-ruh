#!/bin/sh

# Fast typecheck for changed files
CHANGED=$(git diff --cached --name-only --diff-filter=ACM)

# Backend
if echo "$CHANGED" | grep -q "^ruh-backend/"; then
  echo "⚡ Typechecking ruh-backend..."
  cd ruh-backend && node_modules/.bin/tsc --noEmit || exit 1
  cd ..
fi

# Agent builder UI
if echo "$CHANGED" | grep -q "^agent-builder-ui/"; then
  if [ -f "agent-builder-ui/node_modules/.bin/tsc" ]; then
    echo "⚡ Typechecking agent-builder-ui..."
    cd agent-builder-ui && node_modules/.bin/tsc --noEmit || exit 1
    cd ..
  else
    echo "⚠️  Skipping agent-builder-ui typecheck (node_modules not installed)"
  fi
fi

# Admin UI
if echo "$CHANGED" | grep -q "^admin-ui/"; then
  echo "⚡ Typechecking admin-ui..."
  cd admin-ui && node_modules/.bin/tsc --noEmit || exit 1
  cd ..
fi

# Marketplace UI
if echo "$CHANGED" | grep -q "^packages/marketplace-ui/"; then
  echo "⚡ Typechecking marketplace-ui..."
  cd packages/marketplace-ui && node_modules/.bin/tsc --noEmit || exit 1
  cd ..
fi

echo "✓ Pre-commit checks passed"
