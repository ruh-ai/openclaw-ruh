{
  "name": "test-123",
  "version": "1.0.0",
  "agents": {
    "defaults": {
      "model": "gpt-5.2"
    },
    "list": [
      {
        "id": "agent",
        "name": "Agent",
        "skills": ["data-ingestion-openclaw", "test"]
      }
    ]
  },
  "tools": {
    "agentToAgent": {
      "enabled": false,
      "allow": []
    }
  },
  "skills": {
    "entries": {
      "data-ingestion-openclaw": {
        "enabled": true,
        "env": {
          "DATA_INGESTION_BASE_URL": "${DATA_INGESTION_BASE_URL}",
          "DATA_INGESTION_ORG_ID": "${DATA_INGESTION_ORG_ID}",
          "DATA_INGESTION_AGENT_ID": "${DATA_INGESTION_AGENT_ID}",
          "DATA_INGESTION_TOKEN": "${DATA_INGESTION_TOKEN}"
        }
      },
      "test": {
        "enabled": true,
        "env": {
          "DATA_INGESTION_BASE_URL": "${DATA_INGESTION_BASE_URL}",
          "DATA_INGESTION_ORG_ID": "${DATA_INGESTION_ORG_ID}",
          "DATA_INGESTION_AGENT_ID": "${DATA_INGESTION_AGENT_ID}",
          "DATA_INGESTION_TOKEN": "${DATA_INGESTION_TOKEN}"
        }
      }
    }
  },
  "heartbeat": {
    "enabled": false,
    "intervalMinutes": 30
  }
}
