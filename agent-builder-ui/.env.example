NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_COOKIES_DOMAIN=
NEXT_PUBLIC_AUTH_URL=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_MARKETPLACE_URL=
NODE_ENV=development

# Simple Login Password
SIMPLE_LOGIN_PASSWORD=

# OpenClaw Gateway Configuration
OPENCLAW_GATEWAY_URL=
# Still required even when the target gateway uses shared Codex/OpenClaw OAuth
# internally for model access. This token authenticates the bridge to the gateway.
OPENCLAW_GATEWAY_TOKEN=

# Optional Langfuse tracing configuration
LANGFUSE_BASE_URL=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_TRACING_ENVIRONMENT=
LANGFUSE_RELEASE=
