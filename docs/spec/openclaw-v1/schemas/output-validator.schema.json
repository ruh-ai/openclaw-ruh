{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.ruh.ai/spec/v1/schemas/output-validator.schema.json",
  "title": "OpenClaw Output Validator Configuration and Canonical Markers",
  "description": "Defines the pipeline's output-validator config and the canonical marker schemas the runtime ships with. See spec/openclaw-v1/015-output-validator.md.",
  "type": "object",
  "$defs": {
    "OutputValidatorConfig": {
      "description": "The shape of pipeline-manifest.json's output_validator field.",
      "type": "object",
      "required": ["layers", "schemas"],
      "additionalProperties": false,
      "properties": {
        "layers": {
          "type": "array",
          "items": { "enum": ["json", "marker", "heuristic"] },
          "uniqueItems": true,
          "minItems": 1,
          "description": "Which parser layers this pipeline accepts. Order is fixed (json → marker → heuristic) regardless of declaration order."
        },
        "heuristic_confidence_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.6,
          "description": "Below this confidence, Layer 3 results are suppressed and the parse is treated as failed."
        },
        "schemas": {
          "type": "array",
          "items": { "$ref": "#/$defs/MarkerSchemaBinding" },
          "description": "Mapping from marker name to schema reference."
        }
      }
    },
    "MarkerSchemaBinding": {
      "type": "object",
      "required": ["marker", "schema_ref"],
      "additionalProperties": false,
      "properties": {
        "marker": {
          "type": "string",
          "pattern": "^[a-zA-Z_][\\w-]*$",
          "description": "Marker name as it appears in <marker_name attr=\"...\"/>."
        },
        "schema_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to a Zod/JSON schema. Format: 'openclaw-v1:<SchemaName>' for canonical schemas, or a path for pipeline-local schemas."
        }
      }
    },
    "MarkerToken": {
      "description": "A single extracted marker, post-tokenization but pre-validation.",
      "type": "object",
      "required": ["name", "attributes", "raw", "offset"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-zA-Z_][\\w-]*$" },
        "attributes": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "raw": { "type": "string" },
        "offset": { "type": "integer", "minimum": 0 }
      }
    },
    "ParsedMarkerEvent": {
      "description": "A validated marker, ready for emission to consumers.",
      "type": "object",
      "required": ["name", "value"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-zA-Z_][\\w-]*$" },
        "value": {
          "type": "object",
          "description": "The validated, schema-conforming attributes. Shape depends on the marker schema.",
          "additionalProperties": true
        }
      }
    },
    "ValidationFailureDiagnostic": {
      "description": "Emitted to the decision log when a marker fails its schema.",
      "type": "object",
      "required": ["type", "marker_name", "schema", "error", "raw", "layer"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "output_validation_failed" },
        "marker_name": { "type": "string" },
        "schema": { "type": "string", "description": "Schema name that failed." },
        "error": { "type": "string", "description": "Aggregated Zod issue messages." },
        "raw": { "description": "The data that failed validation. Any shape." },
        "layer": { "enum": [1, 2, 3] }
      }
    },
    "ParserFallbackDiagnostic": {
      "description": "Emitted when Layer 3 (heuristic) extraction is used. Layer 1+2 success does not emit this.",
      "type": "object",
      "required": ["type", "layer", "raw_excerpt", "extracted", "confidence"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "parser_fallback" },
        "layer": { "const": 3 },
        "raw_excerpt": { "type": "string" },
        "extracted": { "type": "object", "additionalProperties": true },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "RevealSchema": {
      "description": "Canonical: <reveal name=\"...\" title=\"...\" .../> employee profile reveal marker.",
      "type": "object",
      "required": ["name", "title", "opening", "what_i_heard", "what_i_will_own", "what_i_wont_do", "first_move", "clarifying_question"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "opening": { "type": "string", "minLength": 1 },
        "what_i_heard": { "type": "array", "items": { "type": "string" } },
        "what_i_will_own": { "type": "array", "items": { "type": "string" } },
        "what_i_wont_do": { "type": "array", "items": { "type": "string" } },
        "first_move": { "type": "string", "minLength": 1 },
        "clarifying_question": { "type": "string", "minLength": 1 }
      }
    },
    "ThinkStepSchema": {
      "description": "Canonical: <think_step step=\"...\" status=\"started|complete\"/>.",
      "type": "object",
      "required": ["step", "status"],
      "additionalProperties": false,
      "properties": {
        "step": { "type": "string", "minLength": 1 },
        "status": { "enum": ["started", "complete"] }
      }
    },
    "ThinkResearchFindingSchema": {
      "description": "Canonical: <think_research_finding title=\"...\" summary=\"...\" source=\"...\"/>.",
      "type": "object",
      "required": ["title", "summary"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "source": { "type": "string" }
      }
    },
    "ThinkDocumentReadySchema": {
      "description": "Canonical: <think_document_ready docType=\"...\" path=\"...\"/>.",
      "type": "object",
      "required": ["docType", "path"],
      "additionalProperties": false,
      "properties": {
        "docType": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "PlanSkillSchema": {
      "description": "Canonical: <plan_skill id=\"...\" name=\"...\" description=\"...\" dependencies=\"[...]\" toolType=\"...\" envVars=\"[...]\"/>.",
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1, "pattern": "^[a-z][a-z0-9-]*$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        },
        "toolType": { "type": "string" },
        "envVars": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" }
        }
      }
    },
    "PlanWorkflowSchema": {
      "description": "Canonical: <plan_workflow steps=\"[...]\"/>.",
      "type": "object",
      "required": ["steps"],
      "additionalProperties": false,
      "properties": {
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["skillId"],
            "additionalProperties": false,
            "properties": {
              "skillId": { "type": "string", "minLength": 1, "pattern": "^[a-z][a-z0-9-]*$" },
              "parallel": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
