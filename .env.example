# ─────────────────────────────────────────────────────────────────────────────
# openclaw-ruh — Environment Variables
#
# Copy this file to .env and fill in your values before running:
#   docker compose -f docker-compose.dev.yml up    (development)
#   docker compose up -d                           (production)
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=changeme
POSTGRES_DB=openclaw
# In docker-compose the hostname is "postgres" (the service name).
# For local dev without Docker, use localhost.
DATABASE_URL=postgresql://openclaw:changeme@postgres:5432/openclaw

# ── LLM Provider Keys ─────────────────────────────────────────────────────────
# At least one is required. Priority: OpenRouter → OpenAI → Anthropic → Gemini → Ollama
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=qwen3-coder:30b

# ── Shared Codex/OpenClaw OAuth bootstrap (optional) ─────────────────────────
# If present, new sandboxes prefer these host auth files over API-key bootstrap.
OPENCLAW_SHARED_OAUTH_JSON_PATH=
CODEX_AUTH_JSON_PATH=
OPENCLAW_SHARED_CODEX_MODEL=openai-codex/gpt-5.4

# ── Backend ────────────────────────────────────────────────────────────────────
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost
LOG_LEVEL=info

# JWT auth secrets (change in production!)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# Admin retrofit route token
OPENCLAW_ADMIN_TOKEN=

# Agent credential encryption (64 hex chars = 32 bytes). Leave blank for dev.
AGENT_CREDENTIALS_KEY=

# Sandbox Docker image (build with: cd ruh-backend && bash scripts/build-sandbox-image.sh)
SANDBOX_IMAGE=ruh-sandbox:latest

# ── Sandbox Provider ──────────────────────────────────────────────────────────
# Where to create sandboxes: docker (local containers) or daytona (cloud).
SANDBOX_PROVIDER=docker
# Required only when SANDBOX_PROVIDER=daytona:
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api

# ── Agent Builder UI ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_COOKIES_DOMAIN=
NEXT_PUBLIC_AUTH_URL=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_MARKETPLACE_URL=

# ── Ruh Frontend ──────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL is shared above

# ── Admin UI ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL is shared above

# ── Messaging Channels (optional) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# ── OpenTelemetry / Langfuse (optional) ───────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ruh-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SAMPLE_RATE=1.0

# Langfuse tracing (agent-builder-ui)
LANGFUSE_BASE_URL=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_TRACING_ENVIRONMENT=
LANGFUSE_RELEASE=

# ── Paperclip + OpenSpace (optional) ──────────────────────────────────────────
PAPERCLIP_API_URL=
OPENSPACE_MCP_ENABLED=false
